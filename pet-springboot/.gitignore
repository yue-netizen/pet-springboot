# ============================================
# 宠物领养平台 - Git忽略文件配置
# ============================================

# 编译输出目录
target/
build/
*.class
*.jar
*.war
*.ear
*.nar

# IDE 配置文件
.idea/
*.iml
*.iws
*.ipr
.vscode/
*.swp
*.swo
*~

# Maven
.mvn/
mvnw
mvnw.cmd

# 日志文件
*.log
logs/

# 操作系统文件
.DS_Store
Thumbs.db
Desktop.ini

# 数据文件（包含敏感信息或训练数据）
data/
*.json.bak
*.sql.bak

# 环境配置文件（包含真实密码，不能提交）
.env
.env.local
.env.*.local
application-local.yaml
application-dev.yaml
application-prod.yaml

# 临时文件
*.tmp
*.temp
*.bak
*.cache

# 压缩包（除非是发布版本）
*.tar.gz
*.zip
*.rar
!release/*.zip

# 测试覆盖率报告
coverage/
*.lcov
jacoco.exec

# Node.js (如果前端项目)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Python (如果涉及AI相关)
__pycache__/
*.py[cod]
.Python
env/
venv/
