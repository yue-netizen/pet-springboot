# ============================================
# 宠物领养平台 - 环境变量配置示例
# ============================================
#
# ⚠️⚠️⚠️ 极其重要：请务必在启动前配置所有密码！⚠️⚠️⚠️
#
# 使用说明：
# 1. 复制此文件为 .env（不要将 .env 提交到 Git）
# 2. 根据你的实际环境修改下面的配置
# 3. 确保 .env 在 .gitignore 中（已默认包含）
#
# 🔒 安全要求：
# ✅ 所有密码必须使用强密码（至少16位，混合大小写+数字+特殊字符）
# ✅ 不同服务使用不同密码，禁止重复使用！
# ✅ 定期更换密码（建议每90天）
# ❌ 绝对禁止使用示例中的默认值或简单密码！
#
# 🚫 禁止行为：
# - 不要将 .env 文件提交到 GitHub/GitLab
# - 不要在生产环境使用弱密码（如123456、password等）
# - 不要将密码硬编码到代码中
#
# 💡 推荐做法：
# - 生产环境使用密钥管理服务（如 HashiCorp Vault、AWS Secrets Manager）
# - 或使用配置中心加密存储（Nacos、Apollo）
# - 或使用 Docker Secrets / Kubernetes Secrets
# ============================================

# ----------------------------------------
# 数据库配置 (MySQL)
# ----------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_NAME=pet
DB_USERNAME=root

# ⚠️ 数据库密码：必须修改！建议至少16位
# ❌ 错误示例: 123456, password, admin, root
# ✅ 正确示例: Xk9#mP2$vL5@nQ8&wR1!tY4
DB_PASSWORD=your_secure_password_here

# ----------------------------------------
# Redis 配置
# ----------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379

# ⚠️ Redis 密码：必须设置！（即使本地开发也建议设置）
# Redis 默认无密码，但生产环境必须启用 requirepass
REDIS_PASSWORD=your_redis_password_here

# ----------------------------------------
# RabbitMQ 配置
# ----------------------------------------
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest

# ⚠️ RabbitMQ 密码：生产环境必须修改！
# guest/guest 是默认账号，仅用于本地开发
RABBITMQ_PASSWORD=guest

# ----------------------------------------
# Nacos 配置中心（服务发现和配置管理）
# ----------------------------------------
NACOS_SERVER_ADDR=localhost:8848

# ----------------------------------------
# JWT 密钥配置（极其重要！！！）
# ----------------------------------------
# ⚠️⚠️⚠️ 这是系统安全的核心！必须配置强密钥！⚠️⚠️⚠️
#
# 安全要求：
# ✅ 至少 32 位随机字符串（推荐 64 位）
# ✅ 必须包含大小写字母、数字、特殊字符
# ✅ 每个部署实例使用不同的密钥
# ❌ 禁止使用可预测的字符串
# ❌ 禁止与其他系统共用密钥
#
# 生成强密钥的方法：
# Linux/Mac:
#   openssl rand -base64 48
#
# Windows (PowerShell):
#   powershell -Command "[System.Convert]::ToBase64String((1..48|%{[byte](Get-Random -Max 256)}))"
#
# 在线生成器（不推荐，但可用于测试）：
#   https://generate-secret.vercel.app/64
#
# ❌ 错误示例（禁止使用）：
#   - my-secret-key
#   - pet-adoption-platform-2024
#   - 任何英文单词或短语
#   - 生日、电话号码等个人信息
#
# ✅ 正确示例：
#   JWT_SECRET_KEY="aB3$xK9@mP2&vL7*nQ5!wR8(tY4)zX6"
JWT_SECRET_KEY=your_very_long_and_secure_jwt_secret_key_here_at_least_64_characters_long_random_string

# ----------------------------------------
# 阿里云 OSS 对象存储（文件上传）
# ----------------------------------------
# 获取地址：https://ram.console.aliyun.com/users
# 建议创建 RAM 子账号，只授予 OSS 权限
OSS_ACCESS_KEY_ID=your_oss_access_key_id
OSS_ACCESS_KEY_SECRET=your_oss_access_key_secret
OSS_BUCKET_NAME=your_bucket_name
OSS_ENDPOINT=https://oss-cn-beijing.aliyuncs.com

# ----------------------------------------
# 阿里云 DashScope AI 服务（智能问答）
# ----------------------------------------
# 获取地址：https://dashscope.console.aliyun.com/apiKey
# 用于宠物知识库的AI智能问答功能
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# ----------------------------------------
# SSL/TLS 配置（生产环境必填）
# ----------------------------------------
# 如果启用了 HTTPS，需要配置以下参数
# SSL_KEYSTORE_PATH=/path/to/keystore.p12
# SSL_KEYSTORE_PASSWORD=your_keystore_password
# SSL_KEY_ALIAS=your_alias

# ----------------------------------------
# 服务器端口配置（可选，默认值见各服务配置）
# ----------------------------------------
# GATEWAY_PORT=9000
# USER_SERVICE_PORT=9001
# ADMIN_SERVICE_PORT=9002
# SOCIAL_SERVICE_PORT=9003
# CHAT_SERVICE_PORT=9004
# DONATION_SERVICE_PORT=9005
# RECRUITMENT_SERVICE_PORT=9006
# STORY_SERVICE_PORT=9007
# PET_SERVICE_PORT=9008
# TIPS_SERVICE_PORT=9009

# ----------------------------------------
# 日志级别配置（可选）
# ----------------------------------------
# 生产环境建议设置为 WARN 或 ERROR
# LOG_LEVEL_ROOT=WARN
# LOG_LEVEL_COM_PET=WARN
